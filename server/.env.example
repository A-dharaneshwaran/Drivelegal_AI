# DriveLegal - Server Environment Variables

# The port Express will run on locally
PORT=5000

# MongoDB Connection String (Atlas or local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/drivelegal

# Secret key used for signing and verifying JWT tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Google Gemini API Key for compliance & road rule chatbot queries
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# OpenRouteService API Key for route safety assessment overlay path queries
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here
